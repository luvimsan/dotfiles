#!/usr/bin/env bash

typeset -A pomo_options=(
  [work]=50
  [break]=10
)

typeset -A pomo_icons=(
  [work]="🧠"
  [break]="💤"
)

pomodoro () {
  local val minutes start_time end_time icon display_text
  local cache_file="$HOME/.cache/pomo_status"
  local pid_file="$HOME/.cache/pomo_pid"

  : > "$cache_file"
  pkill -RTMIN+10 dwmblocks 2>/dev/null

  if [[ -n "$1" && -n "${pomo_options[$1]}" ]]; then
    val="$1"
    minutes="${pomo_options[$val]}"
    start_time=$(date +"%H:%M")
    end_time=$(date -d "+${minutes} minutes" +"%H:%M")
    icon="${pomo_icons[$val]}"
    display_text="${val^}"

    paplay "$HOME/sounds/${val}.wav" &>/dev/null &
    notify-send "${icon}  $display_text till $end_time"

    echo -e "${icon}  \033[1m${display_text}\033[0m Session"
    echo -e "⏱  Starts at: \033[32m$start_time\033[0m"
    echo -e "🏁 Ends at:   \033[31m$end_time\033[0m\n"

    (
      trap 'rm -f "$pid_file"; : > "$cache_file"; pkill -RTMIN+10 dwmblocks 2>/dev/null; exit' INT TERM

      echo $$ > "$pid_file"

      for ((i = minutes; i > 0; i--)); do
        done=$((minutes - i))
        percent=$((done * 10 / minutes))

        bar="$(printf '%*s' "$percent" '' | tr ' ' '#')"
        bar+=$(printf '%*s' "$((10 - percent))" '' | tr ' ' '.')

        printf "%s [%s] %dm\n" "$icon" "$bar" "$i" > "$cache_file"
        pkill -RTMIN+10 dwmblocks 2>/dev/null

        sleep 60
      done

      rm -f "$pid_file"
      : > "$cache_file"
      pkill -RTMIN+10 dwmblocks 2>/dev/null
    ) &

    timer --format 24h "${minutes}m"

  else
    echo "Usage: pomodoro [work|break]"
  fi
}

cy() {
  pomodoro work
  while [ -f "$HOME/.cache/pomo_pid" ]; do
    sleep 5
  done
  pomodoro break
}

cy
