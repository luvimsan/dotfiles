        mpc next
F6
        mpc prev

 ============================================

# mouse movements :
# Move mouse left
ctrl + alt + h
    xdotool mousemove_relative -- -26 0

# Move mouse right
ctrl + alt + l
    xdotool mousemove_relative -- 26 0

# Move mouse up
ctrl + alt + k
    xdotool mousemove_relative -- 0 -26

# Move mouse down
ctrl + alt + j
    xdotool mousemove_relative -- 0 26

# Left click
ctrl + alt + space
    xdotool click 1

ctrl + alt + p
    xdotool click 3

# Scroll up
alt + u
    xdotool click 4

# Scroll down
alt + d
    xdotool click 5
